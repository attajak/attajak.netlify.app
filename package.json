{
  "name": "attajak.netlify.app",
  "version": "1.0.0",
  "private": "true",
  "description": "[![Screenshot](./.github/preview.png)](https://hugoblox.com/templates/)",
  "keywords": [
    "attajak",
    "janrak",
    "hugo",
    "blox",
    "blog",
    "netlify"
  ],
  "homepage": "https://github.com/attajak/attajak.netlify.app#readme",
  "bugs": {
    "url": "https://github.com/attajak/attajak.netlify.app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attajak/attajak.netlify.app.git"
  },
  "license": "MIT",
  "author": {
    "name": "attajak",
    "email": "janrak@gmail.com",
    "url": "https://github.com/attajak"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "clean": "hugo mod clean && rm -rf .hugo_build.lock _vendor/ node_modules/ resources/ public/",
    "new": "hugo new content",
    "build": "hugo --gc --minify --logLevel debug --printI18nWarnings --printPathWarnings && pnpm run pagefind",
    "server": "hugo server -D -E -F -M -N -O --disableFastRender --bind 0.0.0.0 -b http://localhost:1313 --logLevel debug",
    "server:production": "pnpm run server -- -e production",
    "update": "hugo mod get -u && hugo mod tidy && pnpm update",
    "npm:pack": "hugo mod npm pack",
    "list:deps": "hugo mod graph && pnpm list",
    "list:content": "hugo list content all",
    "dev": "pnpm run server",
    "preview": "pnpm run server:production",
    "pagefind": "pagefind --site public",
    "upgrade": "pnpx hugoblox upgrade --yes --ci",
    "doctor": "pnpx hugoblox doctor",
    "deploy": "pnpx netlify deploy --prod --dir=public"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.12",
    "@tailwindcss/typography": "^0.5.10",
    "pagefind": "^1.4.0",
    "preact": "^10.27.2",
    "tailwindcss": "^4.1.12"
  },
  "devDependencies": {
    "@netlify/plugin-lighthouse": "^6.0.4",
    "netlify-plugin-hugo-cache-resources": "^0.2.1"
  },
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "packages/hugoautogen"
  ]
}
